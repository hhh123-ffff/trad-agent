NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=postgresql://qrant:qrant_dev@127.0.0.1:5432/qrant_agent
REDIS_URL=redis://127.0.0.1:6380/0
# Keep 0 for manual local runs. Set to 1 to enable APScheduler daily jobs.
MARKETLENS_ENABLE_SCHEDULER=0
# Example for an always-on local deployment:
# MARKETLENS_ENABLE_SCHEDULER=1
# One-click post-market replay scans a bounded batch by default; set empty/full/all for full A-share scan.
MARKETLENS_POST_MARKET_ENABLE_SCAN=1
MARKETLENS_POST_MARKET_SCAN_LIMIT=500
MARKETLENS_POST_MARKET_SCAN_OFFSET=0
# Optional OpenAI-compatible model for controlled post-market research Agents.
# Without these values, Agent runs save a deterministic fallback and the core replay remains available.
MARKETLENS_LLM_BASE_URL=
MARKETLENS_LLM_API_KEY=
MARKETLENS_LLM_MODEL=
MARKETLENS_LLM_TIMEOUT_SECONDS=20
MARKETLENS_AGENT_DAILY_CALL_LIMIT=20
MARKETLENS_AGENT_WORKFLOW_CALL_LIMIT=12
# Tonghuashun/iFinD can power market/history when credentials are available.
MARKETLENS_MARKET_PROVIDER=ths
MARKETLENS_HISTORY_PROVIDER=ths_delayed
MARKETLENS_INFO_PROVIDER=akshare_cninfo
# Free announcement source for post-market replay; fetches CNInfo disclosures by tracked symbols.
AKSHARE_CNINFO_ANNOUNCEMENT_MARKET=沪深京
AKSHARE_CNINFO_ANNOUNCEMENT_CATEGORY=
AKSHARE_CNINFO_ANNOUNCEMENT_KEYWORD=
AKSHARE_CNINFO_ANNOUNCEMENT_LOOKBACK_DAYS=1
AKSHARE_CNINFO_ANNOUNCEMENT_LIMIT=500
# Tushare remains available as a non-default information fallback.
TUSHARE_TOKEN=
TUSHARE_API_URL=http://api.tushare.pro
TUSHARE_NEWS_SRC=sina
THS_QUANTAPI_BASE_URL=https://quantapi.51ifind.com/api/v1
THS_REFRESH_TOKEN=
THS_ACCESS_TOKEN=
THS_HISTORY_FALLBACK_TO_AKSHARE=1
THS_THEME_FALLBACK_TO_AKSHARE=1
THS_MARKET_MAX_UNIVERSE_QUOTES=6000
THS_QUOTE_BATCH_SIZE=300
THS_UNIVERSE_SEARCHSTRING=全部A股
