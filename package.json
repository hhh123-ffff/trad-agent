{
  "name": "marketlens-saas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "api": "uvicorn backend.app.main:app --host 127.0.0.1 --port 8000 --reload",
    "api:ths": "python tools/run_api_ths.py",
    "smoke:replay": "python tools/post_market_replay_smoke.py",
    "smoke:replay:scan": "python tools/post_market_replay_smoke.py --scan",
    "test:api": "pytest backend/tests -q",
    "db:up": "docker compose up -d postgres redis",
    "db:migrate": "python -m backend.app.migrations",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres redis"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
